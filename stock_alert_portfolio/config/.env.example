# 配置文件
# 复制此文件为 .env 并填入实际值

# Tushare Token (可选，用于更稳定的数据源)
TUSHARE_TOKEN=

# 邮件通知配置
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_TO=

# 钉钉通知配置 (可选)
DINGTALK_ENABLED=false
DINGTALK_WEBHOOK=

# 数据库配置
DATABASE_URL=sqlite:///./database/stock_portfolio.db

# 预警检查间隔 (秒)
CHECK_INTERVAL=60

# 默认监控股票列表
DEFAULT_STOCKS=000001,600519,000858
